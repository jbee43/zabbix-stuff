          {
            "macro": "{$ADGUARD.PASSWORD}",
            "type": "SECRET_TEXT",
            "description": "HTTP Basic Auth password for the AdGuard Home web interface."
          },
          {
            "macro": "{$ADGUARD.PORT}",
            "value": "3000",
            "description": "AdGuard Home web interface port."
          },
          {
            "macro": "{$ADGUARD.PROC.HIGH}",
            "value": "0.5",
            "description": "Avg DNS processing time high threshold (seconds). Triggers HIGH severity alert."
