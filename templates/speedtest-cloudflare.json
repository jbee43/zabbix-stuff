          {
            "uuid": "c99707646d2b4a7f87ca7813e7b3f434",
            "name": "Speedtest stats (raw)",
            "type": "HTTP_AGENT",
            "key": "speedtest.cf.stats",
            "delay": "30m",
            "history": "0",
            "value_type": "TEXT",
            "description": "Master item. Fetches Cloudflare /cdn-cgi/trace (PoP + country metadata); JavaScript preprocessing then runs the timed latency / download / upload probes via HttpRequest and returns a merged JSON document. Not stored - dependent items extract individual metrics.",
            "preprocessing": [
              {
                "type": "JAVASCRIPT",
                "parameters": [
                  "var dlBytes = parseInt(\"{$SPEEDTEST.CF.DL_BYTES}\", 10);\nif (isNaN(dlBytes) || dlBytes <= 0) dlBytes = 5000000;\nvar ulBytes = parseInt(\"{$SPEEDTEST.CF.UL_BYTES}\", 10);\nif (isNaN(ulBytes) || ulBytes <= 0) ulBytes = 2000000;\nvar pingSamples = parseInt(\"{$SPEEDTEST.CF.PING_SAMPLES}\", 10);\nif (isNaN(pingSamples) || pingSamples <= 0) pingSamples = 5;\n\nvar errors = [];\nvar out = {\n  download_bps: 0,\n  upload_bps: 0,\n  ping_ms: 0,\n  jitter_ms: 0,\n  colo: \"\",\n  country: \"\",\n  collected_at_ts: Math.floor(Date.now() / 1000)\n};\n\n// Parse /cdn-cgi/trace body (key=value\\n).\ntry {\n  var lines = (value || \"\").split(\"\\n\");\n  for (var i = 0; i < lines.length; i++) {\n    var idx = lines[i].indexOf(\"=\");\n    if (idx > 0) {\n      var k = lines[i].substring(0, idx);\n      var v = lines[i].substring(idx + 1);\n      if (k === \"colo\") out.colo = v;\n      else if (k === \"loc\") out.country = v;\n    }\n  }\n} catch (e) { errors.push(\"trace: \" + e); }\n\n// Latency probes (1-byte fetches; round-trip dominated by TCP/TLS reuse and TTFB).\nvar pings = [];\nfor (var i = 0; i < pingSamples; i++) {\n  try {\n    var pReq = new HttpRequest();\n    var t0 = Date.now();\n    pReq.get(\"https://speed.cloudflare.com/__down?bytes=1\");\n    pings.push(Date.now() - t0);\n  } catch (e) { errors.push(\"ping\" + i + \": \" + e); }\n}\nif (pings.length > 0) {\n  var sum = 0;\n  for (var i = 0; i < pings.length; i++) sum += pings[i];\n  out.ping_ms = sum / pings.length;\n  if (pings.length > 1) {\n    var jSum = 0;\n    for (var i = 1; i < pings.length; i++) jSum += Math.abs(pings[i] - pings[i - 1]);\n    out.jitter_ms = jSum / (pings.length - 1);\n  }\n}\n\n// Download — single timed fetch of dlBytes.\ntry {\n  var dReq = new HttpRequest();\n  var t0 = Date.now();\n  var body = dReq.get(\"https://speed.cloudflare.com/__down?bytes=\" + dlBytes);\n  var elapsed = (Date.now() - t0) / 1000;\n  if (body && elapsed > 0) {\n    out.download_bps = Math.floor((body.length * 8) / elapsed);\n  }\n} catch (e) { errors.push(\"download: \" + e); }\n\n// Upload — build a string payload by doubling, then POST it.\ntry {\n  var payload = \"x\";\n  while (payload.length < ulBytes) payload += payload;\n  if (payload.length > ulBytes) payload = payload.substring(0, ulBytes);\n  var uReq = new HttpRequest();\n  uReq.addHeader(\"Content-Type: application/octet-stream\");\n  var t0 = Date.now();\n  uReq.post(\"https://speed.cloudflare.com/__up\", payload);\n  var elapsed = (Date.now() - t0) / 1000;\n  if (elapsed > 0) {\n    out.upload_bps = Math.floor((payload.length * 8) / elapsed);\n  }\n} catch (e) { errors.push(\"upload: \" + e); }\n\nout.errors = errors;\nout.collected_at_ts = Math.floor(Date.now() / 1000);\nreturn JSON.stringify(out);"
                ]
              }
            ],
            "timeout": "30s",
            "url": "https://speed.cloudflare.com/cdn-cgi/trace",
            "tags": [
              {
                "tag": "component",
                "value": "raw"
              }
            ],
            "triggers": [
              {
                "uuid": "fc9b89a589e2423ca425ca3fac9afdb6",
                "expression": "nodata(/Speedtest Cloudflare by HTTP/speedtest.cf.stats,{$SPEEDTEST.CF.NODATA})=1",
                "name": "No Cloudflare speedtest data received for {$SPEEDTEST.CF.NODATA}",
                "opdata": "Last received: {ITEM.LASTCLOCK}",
                "priority": "WARNING",
                "description": "The Cloudflare speedtest master item has not produced data within the expected interval. Possible causes: Zabbix server JS preprocessing timeout exceeded (lower {$SPEEDTEST.CF.DL_BYTES} / {$SPEEDTEST.CF.UL_BYTES}), Cloudflare unreachable, or DNS/network failure.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "availability"
                  }
                ]
              }
            ]
          },
