            "macro": "{$ADGUARD.PROC.WARNING}",
            "value": "0.1",
            "description": "Avg DNS processing time warning threshold (seconds). Triggers WARNING severity alert."
          },
          {
            "macro": "{$ADGUARD.USER}",
            "description": "HTTP Basic Auth username for the AdGuard Home web interface."
          }
