            ],
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.powers"]
              }
            ]
          },
          {
            "uuid": "3db0282fba2f4e1da6405ab94a3ee8a9",
            "name": "Temperature critical threshold discovery",
            "type": "DEPENDENT",
            "key": "lm.sensors.temp.crit.discovery",
            "description": "Discovers only the temperature sensors that report a hardware-defined critical threshold. Sensors without a temp_crit reading are excluded.",
            "item_prototypes": [
              {
                "uuid": "9318ba0de8b946e490af9eb4d56a86f2",
                "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature critical",
                "type": "DEPENDENT",
                "key": "lm.sensors.temp.crit[{#SENSOR.ID}]",
                "history": "1d",
                "value_type": "FLOAT",
                "trends": "0",
                "units": "\u00b0C",
                "description": "Critical temperature threshold reported by sensor hardware for {#SENSOR.LABEL} on chip {#SENSOR.CHIP}. Exceeding this may cause thermal shutdown.",
                "preprocessing": [
                  {
                    "type": "JSONPATH",
                    "parameters": [
                      "$.temperature_crit[?(@.id==\"{#SENSOR.ID}\")].value.first()"
                    ]
                  },
                  {
                    "type": "DISCARD_UNCHANGED_HEARTBEAT",
                    "parameters": ["1d"]
                  }
                ],
                "master_item": {
                  "key": "lm.sensors.stats"
                },
                "tags": [
                  {
                    "tag": "component",
                    "value": "temperature"
                  },
                  {
                    "tag": "sensor",
                    "value": "{#SENSOR.LABEL}"
                  }
                ]
              }
            ],
            "master_item": {
              "key": "lm.sensors.stats"
            },
            "lld_macro_paths": [
              {
                "lld_macro": "{#SENSOR.CHIP}",
                "path": "$.chip"
              },
              {
                "lld_macro": "{#SENSOR.ID}",
