              },
              {
                "tag": "scope",
                "value": "performance"
              }
            ]
          },
          {
            "uuid": "176c284c5e3c496e98b44e7b9991b55e",
            "name": "Blocked parental",
            "type": "DEPENDENT",
            "key": "adguard.blocked_parental",
            "history": "14d",
            "description": "Total number of DNS queries blocked by parental control. Extracted from /control/stats.",
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.num_replaced_parental"]
              }
            ],
            "master_item": {
              "key": "adguard.stats"
            },
            "tags": [
              {
                "tag": "component",
                "value": "dns"
              },
              {
                "tag": "scope",
                "value": "performance"
              }
            ]
          },
          {
            "uuid": "5a6fc7d4ba064642b2fb2da1be692b8c",
            "name": "Blocked safe browsing",
            "type": "DEPENDENT",
            "key": "adguard.blocked_safebrowsing",
            "history": "14d",
            "description": "Total number of DNS queries blocked by safe browsing protection. Extracted from /control/stats.",
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.num_replaced_safebrowsing"]
              }
            ],
            "master_item": {
              "key": "adguard.stats"
            },
            "tags": [
              {
                "tag": "component",
                "value": "dns"
              },
              {
                "tag": "scope",
                "value": "performance"
              }
            ]
          },
          {
            "uuid": "9b0fb5bbc2b142b681540e778d86f86d",
            "name": "Block percentage",
            "type": "CALCULATED",
            "key": "adguard.block_pct",
            "delay": "5m",
            "history": "14d",
            "value_type": "FLOAT",
            "units": "%",
            "params": "100 * last(//adguard.blocked_filtering) / last(//adguard.dns_queries)",
            "description": "Percentage of DNS queries blocked by filters. Calculated from blocked_filtering / dns_queries.",
            "tags": [
              {
                "tag": "component",
                "value": "dns"
              },
              {
                "tag": "scope",
                "value": "performance"
              }
            ]
          },
          {
            "uuid": "528e3cc3cf9348c6b8dda68fcdfec98f",
            "name": "DNS port",
            "type": "DEPENDENT",
            "key": "adguard.dns_port",
            "history": "1d",
            "trends": "0",
            "description": "DNS listening port reported by AdGuard Home. Extracted from /control/status.",
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.dns_port"]
              },
              {
                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                "parameters": ["1d"]
              }
            ],
            "master_item": {
              "key": "adguard.status"
            },
            "tags": [
              {
                "tag": "component",
                "value": "service"
              },
              {
                "tag": "scope",
                "value": "notice"
              }
            ]
          },
          {
            "uuid": "08921fd033cb4ff8947d0957f7b379d6",
            "name": "DNS queries",
            "type": "DEPENDENT",
            "key": "adguard.dns_queries",
            "history": "14d",
            "description": "Total number of DNS queries processed. Extracted from /control/stats.",
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.num_dns_queries"]
              }
            ],
            "master_item": {
              "key": "adguard.stats"
            },
            "tags": [
              {
                "tag": "component",
                "value": "dns"
              },
              {
                "tag": "scope",
                "value": "performance"
              }
            ]
          },
          {
            "uuid": "d635277aa0cf44f1bb96859d90b9ba51",
            "name": "Protection enabled",
            "type": "DEPENDENT",
            "key": "adguard.protection_enabled",
            "history": "14d",
            "trends": "0",
            "description": "Whether DNS filtering protection is currently enabled (1) or disabled (0). Extracted from /control/status.",
            "valuemap": {
              "name": "AdGuard protection status"
            },
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.protection_enabled"]
              },
              {
                "type": "BOOL_TO_DECIMAL"
              }
            ],
            "master_item": {
              "key": "adguard.status"
            },
            "tags": [
              {
                "tag": "component",
                "value": "service"
              },
              {
                "tag": "scope",
                "value": "availability"
              }
            ],
            "triggers": [
              {
                "uuid": "579d3d70ac424cfc8b954ae1749f595c",
                "expression": "last(/AdGuard Home by HTTP/adguard.protection_enabled)=0",
                "name": "DNS filtering protection is disabled",
                "opdata": "Protection: {ITEM.LASTVALUE1}",
                "priority": "HIGH",
                "description": "AdGuard Home DNS filtering protection has been disabled. All queries will pass through unfiltered until re-enabled.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "availability"
                  }
                ]
              }
            ]
          },
          {
            "uuid": "b2467cfecce44563b5f1da7b2d3dc271",
            "name": "Running",
            "type": "DEPENDENT",
            "key": "adguard.running",
            "history": "14d",
            "trends": "0",
            "description": "Whether the AdGuard Home service is running (1) or stopped (0). Extracted from /control/status.",
            "valuemap": {
              "name": "AdGuard service status"
            },
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.running"]
              },
              {
                "type": "BOOL_TO_DECIMAL"
              }
            ],
            "master_item": {
              "key": "adguard.status"
            },
            "tags": [
              {
                "tag": "component",
                "value": "service"
              },
              {
                "tag": "scope",
                "value": "availability"
              }
            ],
            "triggers": [
              {
                "uuid": "c822aecc754747be96da6982ddac397c",
                "expression": "last(/AdGuard Home by HTTP/adguard.running)=0",
                "name": "AdGuard Home service is not running",
                "opdata": "Status: {ITEM.LASTVALUE1}",
                "priority": "DISASTER",
                "description": "AdGuard Home reports it is not running. DNS resolution via AdGuard is unavailable.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "availability"
                  }
                ]
              }
            ]
          },
          {
            "uuid": "a616e8f622804efab6d6f44dd1b49212",
            "name": "Stats (raw)",
            "type": "HTTP_AGENT",
            "key": "adguard.stats",
            "delay": "5m",
            "history": "0",
            "value_type": "TEXT",
            "authtype": "BASIC",
            "username": "{$ADGUARD.USER}",
            "password": "{$ADGUARD.PASSWORD}",
            "description": "Master item: raw JSON from /control/stats endpoint. Not stored \u2014 dependent items extract individual metrics.",
            "url": "http://{$ADGUARD.HOST}:{$ADGUARD.PORT}/control/stats",
            "tags": [
              {
                "tag": "component",
                "value": "raw"
              },
              {
                "tag": "scope",
                "value": "raw"
              }
            ],
            "triggers": [
              {
                "uuid": "6c480b16035845cfbe997a89492aebc1",
                "expression": "nodata(/AdGuard Home by HTTP/adguard.stats,{$ADGUARD.NODATA})=1",
                "name": "No data received for {$ADGUARD.NODATA}",
                "opdata": "Last received: {ITEM.LASTCLOCK}",
                "priority": "WARNING",
                "description": "No data received from AdGuard Home /control/stats endpoint. Verify the host is reachable, credentials are correct, and the web interface is running.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "availability"
                  }
                ]
              }
            ]
          },
          {
            "uuid": "f45d6efe260c4619a8218cb4784a8a02",
            "name": "Status (raw)",
            "type": "HTTP_AGENT",
            "key": "adguard.status",
            "delay": "5m",
            "history": "0",
            "value_type": "TEXT",
            "authtype": "BASIC",
            "username": "{$ADGUARD.USER}",
            "password": "{$ADGUARD.PASSWORD}",
            "description": "Master item: raw JSON from /control/status endpoint. Not stored \u2014 dependent items extract individual metrics.",
            "url": "http://{$ADGUARD.HOST}:{$ADGUARD.PORT}/control/status",
            "tags": [
              {
                "tag": "component",
                "value": "raw"
              },
              {
                "tag": "scope",
                "value": "raw"
              }
            ]
          },
          {
            "uuid": "cf99f99b20a44bb986ffabfe8b282ea0",
            "name": "Version",
            "type": "DEPENDENT",
            "key": "adguard.version",
            "history": "1d",
            "value_type": "CHAR",
            "description": "AdGuard Home version string. Extracted from /control/status.",
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.version"]
              },
              {
                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                "parameters": ["1d"]
              }
            ],
            "master_item": {
              "key": "adguard.status"
            },
            "tags": [
              {
                "tag": "component",
                "value": "service"
              },
              {
                "tag": "scope",
                "value": "notice"
              }
            ],
            "triggers": [
              {
                "uuid": "f525b952d48248d89e08a4113ce7bfde",
                "expression": "change(/AdGuard Home by HTTP/adguard.version)=1 and length(last(/AdGuard Home by HTTP/adguard.version))>0",
                "name": "AdGuard Home version changed to {ITEM.LASTVALUE1}",
                "opdata": "Version: {ITEM.LASTVALUE1}",
                "priority": "INFO",
                "description": "AdGuard Home has been updated to a new version. Verify the new version is working correctly.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "notice"
                  }
                ]
              }
            ]
          }
        ],
        "tags": [
