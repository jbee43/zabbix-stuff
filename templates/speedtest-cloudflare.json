        "macros": [
          {
            "macro": "{$SPEEDTEST.CF.DL.DISASTER}",
            "value": "500000000",
            "description": "Download speed disaster threshold (bps). Default: 500 Mbps."
          },
          {
            "macro": "{$SPEEDTEST.CF.DL.WARNING}",
            "value": "800000000",
            "description": "Download speed warning threshold (bps). Default: 800 Mbps."
          },
          {
            "macro": "{$SPEEDTEST.CF.DL_BYTES}",
            "value": "5000000",
            "description": "Download payload size in bytes. Default 5 MB - keeps the JS preprocessing step well inside Zabbix server's default time budget. Increase for higher accuracy on fast links if your zabbix_server.conf Timeout allows."
          },
          {
            "macro": "{$SPEEDTEST.CF.NODATA}",
            "value": "90m",
            "description": "No-data timeout for the master item. Should exceed the collection interval (default 30m) plus execution time."
          },
          {
            "macro": "{$SPEEDTEST.CF.PING.HIGH}",
            "value": "50",
            "description": "Ping latency high threshold (ms). Severe degradation for real-time applications."
          },
          {
            "macro": "{$SPEEDTEST.CF.PING.WARNING}",
            "value": "20",
            "description": "Ping latency warning threshold (ms). May affect VoIP, gaming, and video calls."
          },
          {
            "macro": "{$SPEEDTEST.CF.PING_SAMPLES}",
            "value": "5",
            "description": "Number of latency probe requests to average. Default 5."
          },
          {
            "macro": "{$SPEEDTEST.CF.UL.WARNING}",
            "value": "400000000",
            "description": "Upload speed warning threshold (bps). Default: 400 Mbps."
          },
          {
            "macro": "{$SPEEDTEST.CF.UL_BYTES}",
            "value": "2000000",
            "description": "Upload payload size in bytes. Default 2 MB - same trade-off as DL_BYTES (accuracy vs. preprocessing time)."
          }
        ],
