            "macro": "{$ADGUARD.HOST}",
            "value": "localhost",
            "description": "AdGuard Home hostname or IP address."
          },
          {
            "macro": "{$ADGUARD.NODATA}",
            "value": "15m",
            "description": "No-data timeout for the stats master item. Set higher than collection interval to account for transient failures."
