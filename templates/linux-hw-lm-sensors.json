            "type": "DEPENDENT",
            "key": "lm.sensors.power.discovery",
            "description": "Discovers power consumption sensors reported by lm-sensors (e.g. CPU package power, DRAM power). Creates monitoring items per power sensor.",
            "item_prototypes": [
