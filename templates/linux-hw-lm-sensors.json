              },
              {
                "lld_macro": "{#SENSOR.LABEL}",
                "path": "$.label"
              }
            ],
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.temperature_crit"]
              }
            ]
          },
          {
            "uuid": "4cb1f345941d4356b1436519f60df2b0",
            "name": "Temperature sensor discovery",
            "type": "DEPENDENT",
            "key": "lm.sensors.temp.discovery",
            "description": "Discovers temperature sensors reported by lm-sensors (e.g. CPU package, core temps, chipset). Creates monitoring items per sensor with optional max/critical thresholds.",
            "item_prototypes": [
              {
                "uuid": "6d14275df2984358bff1b2e9c17e1743",
                "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature",
                "type": "DEPENDENT",
                "key": "lm.sensors.temp.input[{#SENSOR.ID}]",
                "history": "14d",
                "value_type": "FLOAT",
                "units": "\u00b0C",
                "description": "Current temperature reading from sensor {#SENSOR.LABEL} on chip {#SENSOR.CHIP}.",
                "preprocessing": [
                  {
                    "type": "JSONPATH",
                    "parameters": [
                      "$.temperatures[?(@.id==\"{#SENSOR.ID}\")].input.first()"
                    ]
