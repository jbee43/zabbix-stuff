                "uuid": "ac5ceda6ad4d4fa8b30dd07af1d8fa1d",
                "expression": "avg(/Speedtest Cloudflare by HTTP/speedtest.cf.ping,5m)>{$SPEEDTEST.CF.PING.HIGH}",
