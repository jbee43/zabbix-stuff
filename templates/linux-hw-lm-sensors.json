                "master_item": {
                  "key": "lm.sensors.stats"
                },
                "tags": [
                  {
                    "tag": "component",
                    "value": "temperature"
                  },
                  {
                    "tag": "sensor",
                    "value": "{#SENSOR.LABEL}"
                  }
                ],
                "trigger_prototypes": [
                  {
                    "uuid": "4b063123c70b449bbeb238a9b6603e77",
                    "expression": "avg(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.temp.input[{#SENSOR.ID}],5m)>{$LM.TEMP.DISASTER}",
                    "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature > {$LM.TEMP.DISASTER}\u00b0C",
                    "priority": "DISASTER",
                    "description": "Temperature sensor {#SENSOR.LABEL} on {#SENSOR.CHIP} has exceeded the disaster threshold ({$LM.TEMP.DISASTER}\u00b0C, 5-minute average). Hardware damage is possible.",
                    "tags": [
                      {
                        "tag": "scope",
                        "value": "availability"
                      }
                    ]
                  },
                  {
                    "uuid": "8125d2347e9f417696414d9af5f7d6b1",
                    "expression": "avg(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.temp.input[{#SENSOR.ID}],5m)>{$LM.TEMP.HIGH}",
                    "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature > {$LM.TEMP.HIGH}\u00b0C",
                    "priority": "HIGH",
                    "description": "Temperature sensor {#SENSOR.LABEL} on {#SENSOR.CHIP} is high ({$LM.TEMP.HIGH}\u00b0C, 5-minute average). Thermal throttling may occur.",
                    "dependencies": [
                      {
                        "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature > {$LM.TEMP.DISASTER}\u00b0C",
                        "expression": "avg(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.temp.input[{#SENSOR.ID}],5m)>{$LM.TEMP.DISASTER}"
                      }
                    ],
                    "tags": [
                      {
                        "tag": "scope",
                        "value": "performance"
                      }
                    ]
                  },
                  {
                    "uuid": "c27ea62df20440d190642a3ba3d0640e",
                    "expression": "avg(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.temp.input[{#SENSOR.ID}],5m)>{$LM.TEMP.WARNING}",
                    "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature > {$LM.TEMP.WARNING}\u00b0C",
                    "priority": "WARNING",
                    "description": "Temperature sensor {#SENSOR.LABEL} on {#SENSOR.CHIP} is elevated ({$LM.TEMP.WARNING}\u00b0C, 5-minute average).",
                    "dependencies": [
                      {
                        "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} temperature > {$LM.TEMP.HIGH}\u00b0C",
                        "expression": "avg(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.temp.input[{#SENSOR.ID}],5m)>{$LM.TEMP.HIGH}"
                      }
                    ],
                    "tags": [
                      {
