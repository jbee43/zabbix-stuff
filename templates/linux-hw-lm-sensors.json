    "templates": [
      {
        "uuid": "363a7dda2d03477a980e1241166c1b3e",
        "template": "Linux Hardware lm-sensors by Zabbix agent active",
        "name": "Linux Hardware (lm-sensors) by Zabbix agent active",
        "description": "Linux hardware monitoring via lm-sensors. Discovers and monitors temperature\nsensors, fans, voltage rails, and power sensors automatically.\n\nSetup:\n1. Install lm-sensors: sudo apt install lm-sensors && sudo sensors-detect --auto\n2. Deploy script: sudo cp lm-sensors-stats.py /etc/zabbix/scripts/ && sudo chmod +x /etc/zabbix/scripts/lm-sensors-stats.py\n3. Deploy config: sudo cp linux-hw-lm-sensors.conf /etc/zabbix/zabbix_agent2.d/\n4. Restart agent: sudo systemctl restart zabbix-agent2\n\nRequires: Python 3.6+, lm-sensors package with sensors -j support.",
        "groups": [
          {
            "name": "Templates/Server hardware"
          }
        ],
        "items": [
          {
            "uuid": "b41f49c0f3d0471780adb17b04650b11",
            "name": "Sensor stats (raw)",
            "type": "ZABBIX_ACTIVE",
            "key": "lm.sensors.stats",
            "delay": "2m",
            "history": "0",
            "value_type": "TEXT",
            "description": "Master item: JSON blob with all lm-sensors hardware data from lm-sensors-stats.py. Not stored \u2014 dependent items and discovery rules extract individual metrics via JSONPath.",
            "tags": [
              {
                "tag": "component",
                "value": "raw"
              }
            ],
            "triggers": [
              {
                "uuid": "cea77225c37c45c49fc92ecbfad2d27c",
                "expression": "nodata(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.stats,{$LM.NODATA})=1",
                "name": "No data received for {$LM.NODATA}",
                "opdata": "Last received: {ITEM.LASTCLOCK}",
                "priority": "WARNING",
                "description": "The lm-sensors-stats script has not returned data within the expected interval. Check that the Zabbix agent is running, lm-sensors is installed (sensors -j works), and the Python script is deployed to /etc/zabbix/scripts/.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "availability"
                  }
                ]
              }
            ]
          }
        ],
        "discovery_rules": [
          {
            "uuid": "d29dd1897382429bac187868c013f139",
            "name": "Fan sensor discovery",
            "type": "DEPENDENT",
            "key": "lm.sensors.fan.discovery",
            "description": "Discovers fan speed sensors reported by lm-sensors. Creates monitoring items per fan with low-speed trigger.",
            "item_prototypes": [
              {
                "uuid": "e1c7eceedecc4d4485e36ea4b983db38",
                "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} fan speed",
                "type": "DEPENDENT",
                "key": "lm.sensors.fan.input[{#SENSOR.ID}]",
                "history": "14d",
                "units": "RPM",
                "description": "Fan speed in RPM from sensor {#SENSOR.LABEL} on chip {#SENSOR.CHIP}. A value of 0 may indicate the fan has stopped or is in zero-RPM mode.",
                "preprocessing": [
                  {
                    "type": "JSONPATH",
                    "parameters": [
                      "$.fans[?(@.id==\"{#SENSOR.ID}\")].input.first()"
                    ]
                  }
                ],
                "master_item": {
                  "key": "lm.sensors.stats"
                },
                "tags": [
                  {
                    "tag": "component",
                    "value": "cooling"
                  },
                  {
                    "tag": "sensor",
                    "value": "{#SENSOR.LABEL}"
                  }
                ],
                "trigger_prototypes": [
                  {
                    "uuid": "cbd8c53ceac24a558417ea098598d934",
                    "expression": "avg(/Linux Hardware lm-sensors by Zabbix agent active/lm.sensors.fan.input[{#SENSOR.ID}],5m)<{$LM.FAN.MIN}",
                    "name": "{#SENSOR.CHIP}: {#SENSOR.LABEL} fan speed below {$LM.FAN.MIN} RPM",
                    "priority": "WARNING",
                    "description": "Fan {#SENSOR.LABEL} on {#SENSOR.CHIP} is running below the minimum expected speed ({$LM.FAN.MIN} RPM, 5-minute average). The fan may have failed or be obstructed. Set {$LM.FAN.MIN} to 0 to disable for fans with zero-RPM idle mode.",
                    "tags": [
                      {
                        "tag": "scope",
                        "value": "availability"
                      }
                    ]
                  }
                ]
              }
            ],
            "graph_prototypes": [
              {
                "uuid": "de4a068a2a244587b51c1b9b844d5d74",
                "name": "Fan speed: {#SENSOR.CHIP} \u2014 {#SENSOR.LABEL}",
                "graph_items": [
                  {
                    "drawtype": "GRADIENT_LINE",
                    "color": "42A5F5",
                    "calc_fnc": "ALL",
                    "item": {
                      "host": "Linux Hardware lm-sensors by Zabbix agent active",
                      "key": "lm.sensors.fan.input[{#SENSOR.ID}]"
                    }
                  }
                ]
              }
            ],
            "master_item": {
              "key": "lm.sensors.stats"
            },
            "lld_macro_paths": [
              {
                "lld_macro": "{#SENSOR.CHIP}",
                "path": "$.chip"
              },
              {
                "lld_macro": "{#SENSOR.ID}",
                "path": "$.id"
              },
              {
                "lld_macro": "{#SENSOR.LABEL}",
                "path": "$.label"
              }
            ],
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.fans"]
              }
            ]
          },
          {
            "uuid": "6ad1af8dcc534af68d267fbe6d06e52a",
