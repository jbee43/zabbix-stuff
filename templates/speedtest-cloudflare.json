                "expression": "avg(/Speedtest Cloudflare by HTTP/speedtest.cf.ping,5m)>{$SPEEDTEST.CF.PING.WARNING}",
                "name": "Cloudflare ping latency elevated (> {$SPEEDTEST.CF.PING.WARNING} ms)",
                "opdata": "Last: {ITEM.LASTVALUE1}",
                "priority": "WARNING",
                "description": "Average ping latency exceeds the warning threshold. May affect real-time applications (VoIP, gaming, video calls).",
                "dependencies": [
                  {
                    "name": "Cloudflare ping latency critically high (> {$SPEEDTEST.CF.PING.HIGH} ms)",
                    "expression": "avg(/Speedtest Cloudflare by HTTP/speedtest.cf.ping,5m)>{$SPEEDTEST.CF.PING.HIGH}"
