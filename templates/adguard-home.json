    "templates": [
      {
        "uuid": "e1c400ac5bb449118b1f59d4faa994da",
        "template": "AdGuard Home by HTTP",
        "name": "AdGuard Home by HTTP",
        "description": "AdGuard Home DNS ad-blocker monitoring via HTTP API.\n\nTracks DNS query statistics, blocking rates, average processing time,\nprotection status, and service health.\n\nNo agent required \u2014 uses HTTP agent items against the AdGuard Home\nREST API (/control/stats, /control/status).\n\nSetup:\n1. Set {$ADGUARD.HOST} and {$ADGUARD.PORT} macros on the host\n2. Set {$ADGUARD.USER} and {$ADGUARD.PASSWORD} if authentication is enabled\n3. Ensure the Zabbix server/proxy can reach the AdGuard Home web interface",
        "groups": [
          {
            "name": "Templates"
          }
        ],
        "items": [
          {
            "uuid": "6828fde99d034c429655d47fabaa7bc3",
            "name": "Avg processing time",
            "type": "DEPENDENT",
            "key": "adguard.avg_processing_time",
            "history": "14d",
            "value_type": "FLOAT",
            "units": "s",
            "description": "Average DNS query processing time in seconds. Extracted from /control/stats.",
            "preprocessing": [
              {
                "type": "JSONPATH",
                "parameters": ["$.avg_processing_time"]
              }
            ],
            "master_item": {
              "key": "adguard.stats"
            },
            "tags": [
              {
                "tag": "component",
                "value": "dns"
              },
              {
                "tag": "scope",
                "value": "performance"
              }
            ],
            "triggers": [
              {
                "uuid": "67f3acbea9c84b37aa7b4b4eac4a7f76",
                "expression": "avg(/AdGuard Home by HTTP/adguard.avg_processing_time,5m)>{$ADGUARD.PROC.HIGH}",
                "name": "Avg DNS processing time above {$ADGUARD.PROC.HIGH}s (high)",
                "opdata": "Avg 5m: {ITEM.LASTVALUE1}",
                "priority": "HIGH",
                "description": "The 5-minute average DNS processing time exceeds the high threshold ({$ADGUARD.PROC.HIGH}s). DNS resolution is severely degraded \u2014 investigate upstream resolvers and system resources.",
                "dependencies": [
                  {
                    "name": "Avg DNS processing time above {$ADGUARD.PROC.WARNING}s (warning)",
                    "expression": "avg(/AdGuard Home by HTTP/adguard.avg_processing_time,5m)>{$ADGUARD.PROC.WARNING}"
                  }
                ],
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              },
              {
                "uuid": "0dfc271f75794fa7beb4349c2f9a87f1",
                "expression": "avg(/AdGuard Home by HTTP/adguard.avg_processing_time,5m)>{$ADGUARD.PROC.WARNING}",
                "name": "Avg DNS processing time above {$ADGUARD.PROC.WARNING}s (warning)",
                "opdata": "Avg 5m: {ITEM.LASTVALUE1}",
                "priority": "WARNING",
                "description": "The 5-minute average DNS processing time exceeds the warning threshold ({$ADGUARD.PROC.WARNING}s). This may indicate upstream DNS issues or high load.",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              }
            ]
          },
          {
            "uuid": "210d337f7f3d4915b978e40fb8414be5",
            "name": "Blocked by filters",
            "type": "DEPENDENT",
            "key": "adguard.blocked_filtering",
            "history": "14d",
